[Unit]
Description=WB Meshtastic Control Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/wb-meshtastic-control
ExecStart=/opt/wb-meshtastic-control/venv/bin/uvicorn wb_meshtastic_control.api:app --host 0.0.0.0 --port 8091
StandardOutput=journal
StandardError=journal
SyslogIdentifier=wb-meshtastic
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
